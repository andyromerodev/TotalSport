---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
}

const {
  title = 'ALKILO | Catalogo',
  description = 'Catalogo de productos de ALKILO.',
  image = 'https://raw.githubusercontent.com/andyromerodev/TotalSport/main/public/images/stores/deportes/licras-ciclismo-corte-laser-badana.jpg',
  type = 'website'
} = Astro.props;

const canonicalUrl = Astro.url.href;
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a7f52" />
    <meta name="color-scheme" content="only light" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="msapplication-navbutton-color" content="#0a7f52" />
    <link rel="manifest" href={`${baseUrl}site.webmanifest`} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="ALKILO" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={image} />
    <meta property="og:image:alt" content={title} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <title>{title}</title>
  </head>
  <body>
    <main class="container">
      <a class="site-brand" href={baseUrl}>ALKILO</a>
      <slot />
    </main>
    <script>
      const THEME_COLOR = '#0a7f52';
      const themeMeta = document.querySelector('meta[name="theme-color"]');
      if (themeMeta) {
        themeMeta.setAttribute('content', THEME_COLOR);
      }

      const blurImages = document.querySelectorAll('img[data-blur-up]');
      for (const image of blurImages) {
        const markLoaded = () => image.classList.add('is-loaded');
        if (image.complete) {
          markLoaded();
        } else {
          image.addEventListener('load', markLoaded, { once: true });
          image.addEventListener('error', markLoaded, { once: true });
        }
      }
    </script>
  </body>
</html>
