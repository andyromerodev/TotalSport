---
import type { Product } from '../lib/catalog';
import { buildWhatsAppLink, getProductImages } from '../lib/catalog';

interface Props {
  product: Product;
}

const { product } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const detailsHref = `${baseUrl}productos/${product.id}/`;
const whatsappHref = buildWhatsAppLink(product.name);
const coverImage = getProductImages(product)[0] ?? 'https://placehold.co/640x640?text=Sin+foto';
---

<article class="card">
  <a class="image-link" href={detailsHref}>
    <img
      class="blur-up-image"
      src={coverImage}
      alt={product.name}
      loading="lazy"
      width="640"
      height="640"
      data-blur-up
    />
  </a>

  <div class="card-content">
    <h3>{product.name}</h3>
    <p class="price">{product.priceUsd} USD</p>
    {product.description && <p class="description">{product.description}</p>}

    <div class="actions">
      <a class="btn btn-outline" href={detailsHref}>Ver detalle</a>
      <a class="btn" href={whatsappHref} target="_blank" rel="noreferrer">WhatsApp</a>
    </div>
  </div>
</article>
