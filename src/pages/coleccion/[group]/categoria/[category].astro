---
import MainLayout from '../../../../layouts/MainLayout.astro';
import StoreCatalogPage from '../../../../ui/vue/components/StoreCatalogPage.vue';
import { getLegacyGroupCategoryStaticPaths, getLegacyGroupCategoryPageData } from '../../../../ui/vue/routes/legacyRoutes';

export const getStaticPaths = getLegacyGroupCategoryStaticPaths;

const { store, selectedCategory, catalog } = getLegacyGroupCategoryPageData(
  Astro.params.group ?? '',
  Astro.params.category ?? '',
  import.meta.env.BASE_URL
);
---

<MainLayout title={`ALKILO | ${store.title}`} description={`${selectedCategory ?? ''} en ${store.title}`.trim()}>
  <StoreCatalogPage client:load catalog={catalog} />
</MainLayout>
