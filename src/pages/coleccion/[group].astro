---
import MainLayout from '../../layouts/MainLayout.astro';
import StoreCatalogPage from '../../ui/vue/components/StoreCatalogPage.vue';
import { getLegacyGroupStaticPaths, getLegacyGroupPageData } from '../../ui/vue/routes/legacyRoutes';

export const getStaticPaths = getLegacyGroupStaticPaths;

const { store, catalog } = getLegacyGroupPageData(Astro.params.group ?? '', import.meta.env.BASE_URL);
---

<MainLayout title={`ALKILO | ${store.title}`} description={store.description}>
  <StoreCatalogPage client:load catalog={catalog} />
</MainLayout>
