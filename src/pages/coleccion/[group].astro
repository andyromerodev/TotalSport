---
import { getStoreBySlug, getStores } from '../../lib/catalog';

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const legacyGroup = Astro.params.group ?? '';

export function getStaticPaths() {
  const stores = getStores().map((store) => store.slug);
  const legacy = stores.map((slug) => (slug === 'deportes' ? 'deporte-ciclismo' : slug));
  return legacy.map((group) => ({ params: { group } }));
}

const mappedStore = legacyGroup === 'deporte-ciclismo' ? 'deportes' : legacyGroup;
const targetStore = getStoreBySlug(mappedStore) ? mappedStore : 'deportes';
const target = `${baseUrl}tienda/${targetStore}/`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <title>Redirigiendo...</title>
  </head>
  <body>
    <p>Redirigiendo a la nueva ruta de tiendita...</p>
    <a href={target}>Continuar</a>
  </body>
</html>
