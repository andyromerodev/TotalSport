---
import { getLegacyCategoryRedirectStaticPaths, getLegacyCategoryRedirectTarget } from '../../ui/vue/routes/legacyRoutes';

export const getStaticPaths = getLegacyCategoryRedirectStaticPaths;

const target = getLegacyCategoryRedirectTarget(Astro.params.slug ?? '', import.meta.env.BASE_URL);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <title>Redirigiendo...</title>
  </head>
  <body>
    <p>Redirigiendo a la nueva ruta de tiendita...</p>
    <a href={target}>Continuar</a>
  </body>
</html>
