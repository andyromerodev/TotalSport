---
import { findStoreSlugByCategorySlug, getStores, getStoreCategories, slugifyCategory } from '../../lib/catalog';

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const categorySlug = Astro.params.slug ?? '';
const storeSlug = findStoreSlugByCategorySlug(categorySlug) ?? 'deportes';
const target = `${baseUrl}tienda/${storeSlug}/categoria/${categorySlug}/`;

export function getStaticPaths() {
  const slugs = new Set();
  for (const store of getStores()) {
    for (const category of getStoreCategories(store.slug)) {
      slugs.add(slugifyCategory(category));
    }
  }
  return [...slugs].map((slug) => ({ params: { slug } }));
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <title>Redirigiendo...</title>
  </head>
  <body>
    <p>Redirigiendo a la nueva ruta de tiendita...</p>
    <a href={target}>Continuar</a>
  </body>
</html>
