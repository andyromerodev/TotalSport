---
import MainLayout from '../../layouts/MainLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getStoreBySlug, getStoreCategories, getStoreProductsByCategory, getStores, slugifyCategory } from '../../lib/catalog';

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

export function getStaticPaths() {
  return getStores().map((store) => ({ params: { store: store.slug } }));
}

const storeSlug = Astro.params.store ?? '';
const store = getStoreBySlug(storeSlug) ?? getStores()[0];
const categories = getStoreCategories(store.slug);
const selectedCategory = categories[0];
const selectedProducts = selectedCategory ? getStoreProductsByCategory(store.slug, selectedCategory) : [];
---

<MainLayout title={`Total Sport | ${store.title}`} description={store.description}>
  <header class="hero">
    <p class="eyebrow">Total Sport</p>
    <h1>{store.title}</h1>
    <p class="lead">{store.description}</p>
  </header>

  <nav class="collection-nav" aria-label="Tienditas">
    {
      getStores().map((entry) => (
        <a href={`${baseUrl}tienda/${entry.slug}/`} class={entry.slug === store.slug ? 'is-active' : ''}>{entry.title}</a>
      ))
    }
  </nav>

  {
    categories.length ? (
      <>
        <nav class="category-nav" aria-label="Categorias">
          {
            categories.map((category) => (
              <a href={`${baseUrl}tienda/${store.slug}/categoria/${slugifyCategory(category)}/`} class={category === selectedCategory ? 'is-active' : ''}>
                {category}
              </a>
            ))
          }
        </nav>

        <section class="category-section">
          <div class="section-head">
            <h2>{selectedCategory}</h2>
            <p>{selectedProducts.length} productos</p>
          </div>

          <div class="grid">
            {selectedProducts.map((product) => <ProductCard product={product} />)}
          </div>
        </section>
      </>
    ) : (
      <section class="empty-state">
        <h2>Sin productos por ahora</h2>
        <p>Esta tiendita esta lista para recibir su inventario.</p>
      </section>
    )
  }
</MainLayout>
