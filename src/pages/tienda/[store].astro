---
import MainLayout from '../../layouts/MainLayout.astro';
import StoreCatalogPage from '../../ui/vue/components/StoreCatalogPage.vue';
import { getStaticPaths as _paths, getStorePageData } from '../../ui/vue/routes/storeRoutes';

export const getStaticPaths = _paths;

const { store, catalog } = getStorePageData(Astro.params.store ?? '', import.meta.env.BASE_URL);
---

<MainLayout title={`ALKILO | ${store.title}`} description={store.description}>
  <StoreCatalogPage client:load catalog={catalog} />
</MainLayout>
