---
import MainLayout from '../../../../layouts/MainLayout.astro';
import StoreCatalogPage from '../../../../ui/vue/components/StoreCatalogPage.vue';
import { getStaticPaths as _paths, getStoreCategoryPageData } from '../../../../ui/vue/routes/storeCategoryRoutes';

export const getStaticPaths = _paths;

const { store, selectedCategory, catalog } = getStoreCategoryPageData(
  Astro.params.store ?? '',
  Astro.params.category ?? '',
  import.meta.env.BASE_URL
);
---

<MainLayout title={`ALKILO | ${store.title}`} description={`${selectedCategory ?? ''} en ${store.title}`.trim()}>
  <StoreCatalogPage client:load catalog={catalog} />
</MainLayout>
