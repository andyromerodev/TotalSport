---
import MainLayout from '../../../../layouts/MainLayout.astro';
import ProductCard from '../../../../components/ProductCard.astro';
import { getStores, getStoreBySlug } from '../../../../application/getStores';
import { getStoreCategories } from '../../../../application/getStoreCategories';
import { getStoreProductsByCategory } from '../../../../application/getStoreProductsByCategory';
import { slugifyCategory } from '../../../../lib/slugify';

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

export function getStaticPaths() {
  return getStores().flatMap((store) =>
    getStoreCategories(store.slug).map((category) => ({
      params: {
        store: store.slug,
        category: slugifyCategory(category)
      }
    }))
  );
}

const storeSlug = Astro.params.store ?? '';
const categorySlug = Astro.params.category ?? '';
const store = getStoreBySlug(storeSlug) ?? getStores()[0];
const categories = getStoreCategories(store.slug);
const selectedCategory = categories.find((category) => slugifyCategory(category) === categorySlug) ?? categories[0];
const selectedProducts = selectedCategory ? getStoreProductsByCategory(store.slug, selectedCategory) : [];
---

<MainLayout title={`ALKILO | ${store.title}`} description={`${selectedCategory ?? ''} en ${store.title}`.trim()}>
  <header class="hero">
    <h1>{store.title}</h1>
    <p class="lead">{store.description}</p>
  </header>

  

  <nav class="category-nav" aria-label="Categorias">
    {
      categories.map((category) => (
        <a href={`${baseUrl}tienda/${store.slug}/categoria/${slugifyCategory(category)}/`} class={category === selectedCategory ? 'is-active' : ''}>
          {category}
        </a>
      ))
    }
  </nav>

  <section class="category-section">
    <div class="section-head">
      <h2>{selectedCategory}</h2>
      <p>{selectedProducts.length} productos</p>
    </div>

    <div class="grid">
      {selectedProducts.map((product) => <ProductCard product={product} />)}
    </div>
  </section>
</MainLayout>
