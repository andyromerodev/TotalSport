---
import MainLayout from '../layouts/MainLayout.astro';
import { getProductImages, getStoreProducts, getStores } from '../lib/catalog';

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const stores = getStores().map((store) => {
  const products = getStoreProducts(store.slug);
  return {
    ...store,
    count: products.length,
    coverImage: products[0] ? getProductImages(products[0])[0] : undefined
  };
});
---

<MainLayout title="Total Sport | Tienditas" description="Explora el catalogo por tienditas independientes.">
  <header class="hero">
    <p class="eyebrow">Total Sport</p>
    <h1>Tienditas</h1>
    <p class="lead">Cada tiendita tiene su propio inventario e imagenes para mantener todo organizado.</p>
  </header>

  <section class="collection-grid" aria-label="Tienditas del catalogo">
    {
      stores.map((store) => (
        <a class="collection-card" href={`${baseUrl}tienda/${store.slug}/`}>
          {
            store.coverImage ? (
              <img src={store.coverImage} alt={store.title} loading="lazy" width="640" height="640" />
            ) : (
              <div class="collection-empty">Proximamente</div>
            )
          }
          <div class="collection-card-content">
            <h2>{store.title}</h2>
            <p>{store.description}</p>
            <span>{store.count} productos</span>
          </div>
        </a>
      ))
    }
  </section>
</MainLayout>
