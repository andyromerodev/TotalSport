---
import MainLayout from '../layouts/MainLayout.astro';
import { Image } from 'astro:assets';
import { getStores } from '../application/getStores';
import { getStoreProducts } from '../application/getStoreProducts';
import coverDeportes from '../assets/store-covers/tienda-deportes.webp';
import coverTecnologias from '../assets/store-covers/tienda-tecnologias.webp';
import coverRegalos from '../assets/store-covers/tienda-regalos.webp';
import coverEmbarazadas from '../assets/store-covers/tienda-embarazadas.webp';

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const storeCoverBySlug = {
  deportes: coverDeportes,
  'tecnologia-electronica': coverTecnologias,
  regalos: coverRegalos,
  embarazadas: coverEmbarazadas
};
const storeThemeBySlug: Record<string, { kicker: string; accent: string; soft: string }> = {
  deportes: { kicker: 'Activa', accent: '#0a7f52', soft: '#d8f1e7' },
  'tecnologia-electronica': { kicker: 'Digital', accent: '#0f4aa3', soft: '#d8e5ff' },
  regalos: { kicker: 'Detalles', accent: '#8a3f2d', soft: '#f6ddd6' },
  embarazadas: { kicker: 'Cuidado', accent: '#9a4f76', soft: '#f5dfeb' }
};

const stores = getStores().map((store) => {
  const products = getStoreProducts(store.slug);
  const theme = storeThemeBySlug[store.slug] ?? { kicker: 'Tienda', accent: '#0a7f52', soft: '#d8f1e7' };
  return {
    ...store,
    count: products.length,
    coverImage: storeCoverBySlug[store.slug as keyof typeof storeCoverBySlug],
    theme
  };
});
---

<MainLayout title="ALKILO | Tienditas" description="Explora el catalogo por tienditas independientes.">
  <header class="hero">
    <h1>Tienditas</h1>
    <p class="lead">Explora cada universo de productos por separado para una experiencia rapida y clara.</p>
  </header>

  <section class="collection-grid" aria-label="Tienditas del catalogo">
    {
      stores.map((store, index) => (
        <a
          class={`collection-card store-card store-${store.slug}`}
          href={`${baseUrl}tienda/${store.slug}/`}
          style={`--store-accent:${store.theme.accent};--store-soft:${store.theme.soft};`}
        >
          {
            store.coverImage ? (
              <div class="store-media">
                <Image
                  class="store-cover blur-up-image"
                  src={store.coverImage}
                  sizes="(max-width: 768px) 92vw, 377px"
                  alt={store.title}
                  loading={index === 0 ? 'eager' : 'lazy'}
                  fetchpriority={index === 0 ? 'high' : 'auto'}
                  widths={[420, 560]}
                  format="webp"
                  quality={68}
                  width={560}
                  height={253}
                  data-blur-up
                />
                <div class="store-overlay"></div>
                <span class="store-kicker">{store.theme.kicker}</span>
              </div>
            ) : (
              <div class="collection-empty">Proximamente</div>
            )
          }
          <div class="collection-card-content">
            <h2>{store.title}</h2>
            <p>{store.description}</p>
            <div class="store-meta">
              <span>{store.count} productos</span>
              <span>Entrar</span>
            </div>
          </div>
        </a>
      ))
    }
  </section>
</MainLayout>
