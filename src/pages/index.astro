---
import MainLayout from '../layouts/MainLayout.astro';
import { COLLECTIONS, getProductsByGroup, getProductImages } from '../lib/catalog';

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const collections = COLLECTIONS.map((collection) => {
  const products = getProductsByGroup(collection.slug);
  const coverImage = products.length > 0 ? getProductImages(products[0])[0] : undefined;
  return {
    ...collection,
    count: products.length,
    coverImage
  };
});
---

<MainLayout title="Total Sport | Colecciones" description="Explora el catalogo por colecciones: deporte, tecnologia, regalos y embarazadas.">
  <header class="hero">
    <p class="eyebrow">Total Sport</p>
    <h1>Colecciones</h1>
    <p class="lead">Elige una coleccion para cargar solo los productos que te interesan.</p>
  </header>

  <section class="collection-grid" aria-label="Colecciones del catalogo">
    {
      collections.map((collection) => (
        <a class="collection-card" href={`${baseUrl}coleccion/${collection.slug}/`}>
          {
            collection.coverImage ? (
              <img src={collection.coverImage} alt={collection.title} loading="lazy" width="640" height="640" />
            ) : (
              <div class="collection-empty">Próximamente</div>
            )
          }
          <div class="collection-card-content">
            <h2>{collection.title}</h2>
            <p>{collection.description}</p>
            <span>{collection.count} productos</span>
          </div>
        </a>
      ))
    }
  </section>
</MainLayout>
