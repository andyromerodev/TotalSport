---
import MainLayout from '../layouts/MainLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getCategories, getProductsByCategory } from '../lib/catalog';

const categories = getCategories();
const productsByCategory = getProductsByCategory();
const categorySlugs = categories.map((category) => ({
  name: category,
  slug: category.toLowerCase().replaceAll(' ', '-')
}));

const selectedSlug = Astro.url.searchParams.get('cat') ?? categorySlugs[0]?.slug;
const selectedCategory = categorySlugs.find((entry) => entry.slug === selectedSlug)?.name ?? categories[0];
const selectedProducts = productsByCategory.get(selectedCategory) ?? [];
---

<MainLayout title="Total Sport | Catalogo" description="Catalogo de productos de Total Sport ordenado por categorias.">
  <header class="hero">
    <p class="eyebrow">Total Sport</p>
    <h1>Catalogo de productos</h1>
    <p class="lead">Selecciona una categoria y escribe por WhatsApp para confirmar tu pedido.</p>
  </header>

  <nav class="category-nav" aria-label="Categorias">
    {
      categorySlugs.map((entry) => (
        <a href={`?cat=${entry.slug}`} class={entry.name === selectedCategory ? 'is-active' : ''}>
          {entry.name}
        </a>
      ))
    }
  </nav>

  <section class="category-section" id={selectedCategory.toLowerCase().replaceAll(' ', '-')}>
    <div class="section-head">
      <h2>{selectedCategory}</h2>
      <p>{selectedProducts.length} productos</p>
    </div>

    <div class="grid">
      {selectedProducts.map((product) => <ProductCard product={product} />)}
    </div>
  </section>
</MainLayout>
