---
import MainLayout from '../layouts/MainLayout.astro';
import StoreIndexPage from '../ui/vue/components/StoreIndexPage.vue';
import { getHomePageData } from '../ui/vue/routes/homeRoutes';

const stores = await getHomePageData(import.meta.env.BASE_URL);
---

<MainLayout title="ALKILO | Tienditas" description="Explora el catalogo por tienditas independientes.">
  <StoreIndexPage client:load stores={stores} />
</MainLayout>
