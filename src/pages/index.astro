---
import MainLayout from '../layouts/MainLayout.astro';
import { getStoreProducts, getStores } from '../lib/catalog';

const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const storeCoverBySlug: Record<string, string> = {
  deportes: `${baseUrl}images/tienda-deportes.jpg`,
  'tecnologia-electronica': `${baseUrl}images/tienda-tecnologias.jpg`,
  regalos: `${baseUrl}images/tienda-regalos.jpg`,
  embarazadas: `${baseUrl}images/tienda-embarazadas.jpg`
};

const stores = getStores().map((store) => {
  const products = getStoreProducts(store.slug);
  return {
    ...store,
    count: products.length,
    coverImage: storeCoverBySlug[store.slug]
  };
});
---

<MainLayout title="Total Sport | Tienditas" description="Explora el catalogo por tienditas independientes.">
  <header class="hero">
    <p class="eyebrow">Total Sport</p>
    <h1>Tienditas</h1>
    <p class="lead">Cada tiendita tiene su propio inventario e imagenes para mantener todo organizado.</p>
  </header>

  <section class="collection-grid" aria-label="Tienditas del catalogo">
    {
      stores.map((store) => (
        <a class="collection-card" href={`${baseUrl}tienda/${store.slug}/`}>
          {
            store.coverImage ? (
              <img class="store-cover" src={store.coverImage} alt={store.title} loading="lazy" width="640" height="640" />
            ) : (
              <div class="collection-empty">Proximamente</div>
            )
          }
          <div class="collection-card-content">
            <h2>{store.title}</h2>
            <p>{store.description}</p>
            <span>{store.count} productos</span>
          </div>
        </a>
      ))
    }
  </section>
</MainLayout>

<script>
  const covers = document.querySelectorAll('.store-cover');
  for (const cover of covers) {
    const markLoaded = () => cover.classList.add('is-loaded');
    if (cover.complete) {
      markLoaded();
    } else {
      cover.addEventListener('load', markLoaded, { once: true });
      cover.addEventListener('error', markLoaded, { once: true });
    }
  }
</script>
