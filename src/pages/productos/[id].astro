---
import MainLayout from '../../layouts/MainLayout.astro';
import { getAllProductsUseCase } from '../../application/GetAllProductsUseCase';
import { getProductByIdUseCase } from '../../application/GetProductByIdUseCase';
import { getProductImages } from '../../lib/productImages';
import { normalizeBaseUrl, toProductDetailUiState } from '../../ui/vue/adapters/catalogViewModelMappers';
import ProductDetailPage from '../../ui/vue/components/ProductDetailPage.vue';

export function getStaticPaths() {
  return getAllProductsUseCase().map((product) => ({
    params: { id: product.id }
  }));
}

const product = getProductByIdUseCase(Astro.params.id ?? '');
const baseUrl = normalizeBaseUrl(import.meta.env.BASE_URL);

if (!product) {
  return Astro.redirect(baseUrl);
}

const productDetailUiState = toProductDetailUiState(product, baseUrl);
const shareImage = getProductImages(product)[0] ?? 'https://placehold.co/900x900?text=Sin+foto';
---

<MainLayout
  title={`${product.name} | ALKILO`}
  description={product.description ?? product.name}
  image={shareImage}
  type="article"
>
  <ProductDetailPage client:load product={productDetailUiState} />
</MainLayout>
