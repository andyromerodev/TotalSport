---
import MainLayout from '../../layouts/MainLayout.astro';
import { buildWhatsAppLink, getProductImages, getProducts, getProductById } from '../../lib/catalog';

export function getStaticPaths() {
  return getProducts().map((product) => ({
    params: { id: product.id }
  }));
}

const product = getProductById(Astro.params.id ?? '');

if (!product) {
  return Astro.redirect('/');
}

const whatsappHref = buildWhatsAppLink(product.name);
const images = getProductImages(product);
---

<MainLayout title={`${product.name} | Total Sport`} description={product.description ?? product.name}>
  <a href="/" class="back-link">Regresar al catalogo</a>

  <article class="product-detail">
    <div class="gallery">
      <img src={images[0] ?? 'https://placehold.co/900x900?text=Sin+foto'} alt={product.name} loading="eager" width="900" height="900" />
      {
        images.length > 1 ? (
          <div class="thumb-grid">
            {images.slice(1).map((image, index) => (
              <img src={image} alt={`${product.name} foto ${index + 2}`} loading="lazy" width="300" height="300" />
            ))}
          </div>
        ) : null
      }
    </div>

    <div>
      <p class="eyebrow">{product.category}</p>
      <h1>{product.name}</h1>
      <p class="price">{product.priceUsd} USD</p>
      {product.description && <p class="description">{product.description}</p>}

      {
        product.variants?.length ? (
          <ul class="variants">
            {product.variants.map((variant) => <li><strong>{variant.name}:</strong> {variant.values.join(', ')}</li>)}
          </ul>
        ) : null
      }

      <a class="btn" href={whatsappHref} target="_blank" rel="noreferrer">Solicitar por WhatsApp</a>
    </div>
  </article>
</MainLayout>
