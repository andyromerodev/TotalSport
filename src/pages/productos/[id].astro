---
import MainLayout from '../../layouts/MainLayout.astro';
import ProductDetailPage from '../../ui/vue/components/ProductDetailPage.vue';
import { getStaticPaths as _paths, getProductPageData } from '../../ui/vue/routes/productRoutes';

export const getStaticPaths = _paths;

const pageData = getProductPageData(Astro.params.id ?? '', import.meta.env.BASE_URL);
if (!pageData) return Astro.redirect(import.meta.env.BASE_URL);

const { product, uiState, shareImage } = pageData;
---

<MainLayout
  title={`${product.name} | ALKILO`}
  description={product.description ?? product.name}
  image={shareImage}
  type="article"
>
  <ProductDetailPage client:load product={uiState} />
</MainLayout>
